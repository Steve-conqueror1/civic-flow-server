{
  "name": "server",
  "version": "1.0.0",
  "description": "backend server for civic flow web app",
  "license": "ISC",
  "author": "Stephen",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:migrate": "npx drizzle-kit migrate",
    "docker:run": "docker compose up -d --build",
    "docker:stop": "docker compose down",
    "initDB": "tsx src/seed/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@bull-board/express": "^6.20.5",
    "@scalar/express-api-reference": "^0.9.2",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "otplib": "^13.3.0",
    "pg": "^8.18.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
